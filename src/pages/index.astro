    transition: all 0.15s;
  }
  #settings-modal input[type="radio"]:checked {
    border-color: var(--color-primary);
    border-width: 4px;
  }

  /* Queue banner */
  #queue-banner {
    font-family: var(--font-mono);
  }

  /* Focus lock */
  #focus-lock {
    z-index: 45;
  }

  /* Tour */
  #tour-overlay {
    z-index: 100;
  }
  #tour-spotlight {
    z-index: 101;
    box-shadow: 0 0 0 2px var(--color-cyan), 0 0 0 9999px rgba(0,0,0,0.5);
  }
  #tour-tooltip {
    z-index: 102;
  }

  /* Scanline overlay */
  .scanline-overlay {
    position: fixed;
    inset: 0;
    z-index: 9998;
    pointer-events: none;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.015) 2px,
      rgba(0,0,0,0.015) 4px
    );
  }
  :root.dark .scanline-overlay {
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(255,255,255,0.012) 2px,
      rgba(255,255,255,0.012) 4px
    );
  }

  /* Animated gradient text */
  @keyframes gradient-flow {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
  .animate-gradient-text {
    background: linear-gradient(90deg, var(--color-cyan), var(--color-gradient-develop-start), var(--color-violet), var(--color-cyan));
    background-size: 300% auto;
    -webkit-background-clip: text;
