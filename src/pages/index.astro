        <div class="bg-gradient-develop-start h-full w-full transition-all duration-300" id="zen-timer-progress"></div>
      </div>
    </div>

    <div class="flex items-center justify-center gap-4">
      <button id="zen-timer-toggle" class="px-8 py-3 bg-primary text-on-primary font-medium rounded-pill transition-all shadow-level-3">
