            <option value="3">3</option>
            <option value="5">5</option>
            <option value="0">All</option>
          </select>
        </div>
        <div>
          <span class="block text-[10px] font-mono uppercase tracking-wider text-mute mb-2">Tour</span>
          <button id="restart-tour-btn" class="text-xs font-mono text-body hover:text-ink border border-hairline px-3 py-1.5 rounded hover:bg-canvas-soft-2 transition-all cursor-pointer">Show intro tour</button>
        </div>
      </div>
    </div>
  </div>

  <!-- One-Task Focus Lock -->
  <div id="focus-lock" class="fixed inset-0 z-40 bg-canvas-soft hidden">
    <div class="max-w-2xl mx-auto px-6 py-16 flex flex-col h-full">
      <div class="flex items-center justify-between mb-8">
        <span class="caption-mono text-xs text-mute uppercase tracking-wider">Focus Target</span>
        <button id="focus-lock-exit" class="text-xs font-mono text-body hover:text-ink border border-hairline px-3 py-1 rounded hover:bg-canvas transition-all cursor-pointer">Back to all tasks</button>
      </div>
      <div class="flex-1 flex flex-col items-center justify-center space-y-8 text-center">
        <div class="w-12 h-12 rounded-full bg-gradient-develop-start/10 flex items-center justify-center">
          <svg class="w-6 h-6 text-gradient-develop-start" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h2 id="focus-lock-title" class="display-lg text-ink">No task selected</h2>
        <p id="focus-lock-subtitle" class="body-md text-mute max-w-md">Focus on this single task. Everything else can wait.</p>
        <div class="flex items-center gap-4">
          <button id="focus-lock-start-btn" class="px-6 py-2 bg-primary text-on-primary font-medium rounded-pill text-sm transition-all shadow-level-2">
            Start timer
          </button>
          <button id="focus-lock-complete-btn" class="px-6 py-2 border border-hairline bg-canvas text-ink rounded-pill text-sm transition-all hover:bg-canvas-soft shadow-level-1">
            Mark done
          </button>
        </div>
      </div>
      <div class="mt-auto pt-8 border-t border-hairline">
        <div class="flex items-center justify-between">
          <span class="text-[11px] font-mono text-mute">Next in queue</span>
          <span id="focus-lock-next" class="text-xs text-body">—</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Onboarding Tour -->
  <div id="tour-overlay" class="fixed inset-0 z-50 hidden">
    <div id="tour-spotlight" class="absolute rounded-lg shadow-[0_0_0_9999px_rgba(0,0,0,0.5)] transition-all duration-300 pointer-events-none hidden"></div>
    <div id="tour-tooltip" class="absolute max-w-xs bg-canvas border border-hairline rounded-lg shadow-level-5 p-5 hidden transition-all duration-300">
      <div class="flex items-center justify-between mb-3">
        <span class="caption-mono text-[10px] text-mute uppercase tracking-wider" id="tour-step-indicator">1 / 4</span>
        <button id="tour-skip-btn" class="text-[11px] font-mono text-mute hover:text-ink transition-colors cursor-pointer">Skip →</button>
      </div>
      <h4 class="display-sm text-sm text-ink mb-1" id="tour-title">Welcome</h4>
      <p class="body-sm text-body" id="tour-desc">Tour description</p>
      <div class="flex items-center justify-between mt-4 pt-3 border-t border-hairline">
        <div class="flex items-center gap-1.5" id="tour-dots"></div>
        <div class="flex items-center gap-2">
          <button id="tour-prev-btn" class="text-[11px] font-mono text-mute hover:text-ink px-2 py-1 rounded hover:bg-canvas-soft-2 transition-all cursor-pointer hidden">Back</button>
          <button id="tour-next-btn" class="text-xs font-medium bg-primary text-on-primary px-4 py-1.5 rounded-pill hover:opacity-90 transition-all cursor-pointer">Next</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Confetti Canvas Overlay -->
  <canvas id="confetti-canvas" class="fixed inset-0 z-[9999] pointer-events-none hidden"></canvas>

  <!-- Scanline Overlay (AI screen aesthetic) -->
  <div class="scanline-overlay"></div>

  <!-- Toast Notification System container (slides in from bottom right) -->
  <div id="toast-container" class="fixed bottom-6 right-6 z-50 space-y-2 pointer-events-none max-w-sm w-full"></div>

  <!-- Professional Footer -->
  <footer class="mt-auto border-t border-hairline bg-canvas relative z-10 transition-all duration-300">
    <div class="max-w-[1400px] w-full mx-auto px-4 md:px-6 py-12 flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-mute" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M15 50 L35 70 L60 45" stroke="currentColor" stroke-width="10" stroke-linecap="round" stroke-linejoin="round"/>
          <polygon points="60,18 86,45 60,72" fill="currentColor"/>
        </svg>
        <span class="caption-mono text-xs text-mute">
          Plan today. Play tomorrow. Built with Astro & Tailwind 4.
        </span>
      </div>
      <div class="flex items-center gap-6">
        <a href="#" class="caption-mono text-xs text-body hover:text-ink transition-colors underline decoration-hairline">
          Back to top
        </a>
      </div>
    </div>
  </footer>
</Layout>

<style>
  /* Custom Styles for Interactive Elements */

  /* Nav hover gradient */
  .nav-hover-gradient:hover {
    background: linear-gradient(90deg, var(--color-cyan), var(--color-gradient-develop-start), var(--color-violet));
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .tab-pill {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--color-body);
    background-color: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-pill-sm);
    padding: 4px 16px;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
