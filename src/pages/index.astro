  }
  @keyframes streak-fire {
    0%, 100% { text-shadow: 0 0 4px #f5a623, 0 0 8px #f5a623; }
    50% { text-shadow: 0 0 8px #ff4d4d, 0 0 16px #ff4d4d; }
  }
  .animate-streak-skull {
    animation: streak-skull 2s ease-in-out infinite;
  }
  @keyframes streak-skull {
    0%, 100% { transform: scale(1); opacity: 0.8; }
    50% { transform: scale(1.15); opacity: 1; }
  }
  .animate-streak-crown {
    animation: streak-crown 1s ease-in-out infinite;
  }
  @keyframes streak-crown {
    0%, 100% { transform: translateY(0) scale(1); filter: brightness(1); }
    50% { transform: translateY(-3px) scale(1.08); filter: brightness(1.4); }
  }
</style>

<script>
  // CLIENT STATE MANAGEMENT
  interface Task {
    id: string;
    title: string;
    category: 'work' | 'personal' | 'leisure';
    priority: 'low' | 'medium' | 'high';
    dueDate: string;
    completed: boolean;
    focusTimeSpent: number; // in seconds
    createdAt: number;
  }

  let tasks: Task[] = [];
  let filterType = 'all';
  let searchQuery = '';
  let activeTimerId: number | null = null;
  let timerDuration = 1500; // 25 minutes default
  let timerRemaining = 1500;
  let timerRunning = false;
  let focusAccumulatedThisSession = 0;
  let timerWasPaused = false;
  let linkedTaskId: string | null = null;
  let isZenMode = false;
  let completedOpen = false;

  // ADHD-feature state
  let isQueueMode = true;
  let queue: Task[] = [];
  let isFocusLocked = false;
  let focusLockedTaskId: string | null = null;
  let settings = { streakType: 'tasks', queueSize: 3 };
  let streakData = { current: 0, best: 0, lastActiveDate: '', dailyDoneToday: false };
  let xpData = { total: 0, level: 1 };
  const XP_PER_LEVEL = 100;

  // Local Storage Keys
  const STORAGE_KEY = 'plan-today-tasks-db';
  const METRIC_KEY = 'plan-today-focus-total';
  const XP_KEY = 'plan-today-xp';
  const STREAK_KEY = 'plan-today-streak';
  const SETTINGS_KEY = 'plan-today-settings';
  const QUEUE_DATE_KEY = 'plan-today-queue-date';
  const TOUR_KEY = 'plan-today-tour-done';

  // Tour data
  const TOUR_STEPS = [
    { targetId: 'quick-add-input', title: 'Add tasks instantly.', desc: 'Type a task and hit Enter. No forms, no clicks. That\'s the whole flow.', placement: 'bottom' },
    { targetId: 'active-tasks-list', title: 'Your daily queue.', desc: 'Your top tasks for today, auto-picked by priority & due date. Lock onto one.', placement: 'top' },
    { targetId: 'timer-toggle-btn', title: 'Focus timer.', desc: 'Pick a task, choose duration, hit Start. Track deep work in focused blocks.', placement: 'top' },
    { targetId: 'stat-completion-pct', title: 'Streaks & XP.', desc: 'Complete tasks → earn XP → level up. Don\'t break the streak.', placement: 'top' }
  ];
  let tourStep = -1;

  // INITIALIZE STATE
  function init() {
    loadData();
    loadXpData();
    loadStreakData();
    loadSettings();
    checkStreak();
    generateQueue();
    setupEventListeners();
    updateUI();
    renderXpDisplay();
    const isDark = document.documentElement.classList.contains('dark');
    updateDarkModeIcon(isDark);
    if (!localStorage.getItem(TOUR_KEY)) startTour();
  }

  function loadData() {
    const saved = localStorage.getItem(STORAGE_KEY);
    if (saved) {
      try {
        tasks = JSON.parse(saved);
      } catch (e) {
        tasks = [];
      }
    } else {
      // Default placeholder tasks
      tasks = [
        {
          id: '1',
          title: 'Plan the upcoming workspace deployment schedule',
          category: 'work',
          priority: 'high',
          dueDate: new Date().toISOString().split('T')[0],
          completed: false,
          focusTimeSpent: 1200,
          createdAt: Date.now() - 3600000
        },
        {
          id: '2',
          title: 'Review web interface guidelines documentation',
          category: 'work',
          priority: 'medium',
          dueDate: '',
          completed: false,
          focusTimeSpent: 0,
          createdAt: Date.now() - 7200000
        },
        {
          id: '3',
          title: 'Hydrate properly and go for an evening run',
          category: 'personal',
          priority: 'low',
          dueDate: '',
          completed: true,
          focusTimeSpent: 0,
          createdAt: Date.now() - 10800000
        }
      ];
      saveData();
    }
  }

  function saveData() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(tasks));
  }

  // === ADHD FEATURES: XP, STREAK, QUEUE ===
  function loadXpData() {
    const saved = localStorage.getItem(XP_KEY);
    if (saved) {
      try { xpData = JSON.parse(saved); } catch (e) { xpData = { total: 0, level: 1 }; }
    }
  }

  function saveXpData() {
    localStorage.setItem(XP_KEY, JSON.stringify(xpData));
  }

  function loadStreakData() {
    const saved = localStorage.getItem(STREAK_KEY);
    if (saved) {
      try { streakData = JSON.parse(saved); } catch (e) { resetStreakData(); }
    }
  }

  function saveStreakData() {
    localStorage.setItem(STREAK_KEY, JSON.stringify(streakData));
  }

  function resetStreakData() {
    streakData = { current: 0, best: 0, lastActiveDate: '', dailyDoneToday: false };
  }

  function loadSettings() {
    const saved = localStorage.getItem(SETTINGS_KEY);
    if (saved) {
      try { settings = JSON.parse(saved); } catch (e) { settings = { streakType: 'tasks', queueSize: 3 }; }
    }
  }

  function saveSettings() {
    localStorage.setItem(SETTINGS_KEY, JSON.stringify(settings));
  }

  function checkStreak() {
    const today = new Date().toISOString().split('T')[0];
    if (streakData.lastActiveDate === today) {
      streakData.dailyDoneToday = true;
      return;
    }
    const yesterday = new Date(Date.now() - 86400000).toISOString().split('T')[0];
    if (streakData.lastActiveDate !== yesterday) {
      streakData.current = 0;
      streakData.dailyDoneToday = false;
      saveStreakData();
    }
  }

  function recordActivity() {
    const today = new Date().toISOString().split('T')[0];
    if (!streakData.dailyDoneToday) {
      if (streakData.lastActiveDate !== today) {
        streakData.current++;
        streakData.best = Math.max(streakData.best, streakData.current);
      }
      streakData.lastActiveDate = today;
      streakData.dailyDoneToday = true;
      saveStreakData();
    }
  }

  function addXp(amount: number) {
    const oldLevel = xpData.level;
    xpData.total += amount;
    xpData.level = Math.floor(xpData.total / XP_PER_LEVEL) + 1;
    saveXpData();
    renderXpDisplay();
    if (xpData.level > oldLevel) {
      triggerConfetti();
      showToast(`🎉 LEVEL UP! You're now level ${xpData.level}!`);
      const statLvl = document.getElementById('stat-level');
      if (statLvl) { statLvl.classList.remove('animate-level-up'); void statLvl.offsetWidth; statLvl.classList.add('animate-level-up'); }
    }
  }

  function getTaskXp(task: Task): number {
    const scores = { low: 10, medium: 25, high: 50 };
    return scores[task.priority];
  }

  function getXpForLevel(level: number): number {
    return (level - 1) * XP_PER_LEVEL;
  }

  function renderXpDisplay() {
    const xpInLevel = xpData.total - getXpForLevel(xpData.level);
    const xpPct = Math.min(100, (xpInLevel / XP_PER_LEVEL) * 100);
    const statLevel = document.getElementById('stat-level');
    if (statLevel) statLevel.textContent = xpData.level.toString();
    const statBar = document.getElementById('stat-xp-bar');
    if (statBar) statBar.style.width = `${xpPct}%`;
    const currentEl = document.getElementById('stat-xp-current');
    if (currentEl) currentEl.textContent = xpInLevel.toString();
    const nextEl = document.getElementById('stat-xp-next');
    if (nextEl) nextEl.textContent = XP_PER_LEVEL.toString();
    const bestStreak = document.getElementById('stat-best-streak');
    if (bestStreak) bestStreak.textContent = streakData.best.toString();
  }

  function updateStreakDisplay() {
    const streakEl = document.getElementById('nav-streak-count');
    if (streakEl) streakEl.textContent = streakData.current.toString();
    const icon = document.getElementById('nav-streak-icon');
    const glow = document.getElementById('streak-glow');
    if (!icon) return;
    icon.removeAttribute('class');
    icon.classList.add('text-xs');
    if (glow) {
      glow.classList.add('opacity-0');
      glow.classList.remove('opacity-60', 'opacity-80', 'opacity-100');
    }
    if (streakData.current >= 30) {
      icon.innerHTML = '👑';
      icon.classList.add('animate-streak-crown');
      if (glow) { glow.classList.remove('opacity-0'); glow.classList.add('opacity-100'); }
    } else if (streakData.current >= 14) {
      icon.innerHTML = '💀';
      icon.classList.add('animate-streak-skull');
      if (glow) { glow.classList.remove('opacity-0'); glow.classList.add('opacity-80'); }
    } else if (streakData.current >= 7) {
      icon.innerHTML = '🔥';
      icon.classList.add('animate-streak-fire');
      if (glow) { glow.classList.remove('opacity-0'); glow.classList.add('opacity-60'); }
    } else if (streakData.current >= 3) {
      icon.innerHTML = '🔥';
    } else if (streakData.current > 0) {
      icon.innerHTML = '⚡';
    } else {
      icon.innerHTML = '○';
    }
  }

  function generateQueue() {
    const today = new Date().toISOString().split('T')[0];
    const lastQueueDate = localStorage.getItem(QUEUE_DATE_KEY);
    const active = tasks.filter(t => !t.completed);
    if (active.length === 0) { queue = []; return; }
    if (lastQueueDate !== today) {
      localStorage.setItem(QUEUE_DATE_KEY, today);
      const queueLimit = settings.queueSize > 0 ? settings.queueSize : active.length;
      queue = scoreSortTasks(active).slice(0, queueLimit);
      if (queue.length === 0) queue = active.slice(0, queueLimit);
    } else {
      const queueLimit = settings.queueSize > 0 ? settings.queueSize : active.length;
      queue = scoreSortTasks(active).slice(0, queueLimit);
    }
  }

  function scoreSortTasks(taskList: Task[]): Task[] {
    return [...taskList].sort((a, b) => {
      let scoreA = 0, scoreB = 0;
      const priorityScores = { high: 30, medium: 15, low: 0 };
      scoreA += priorityScores[a.priority];
      scoreB += priorityScores[b.priority];
      if (a.dueDate) {
        const daysUntilDue = (new Date(a.dueDate).getTime() - Date.now()) / 86400000;
        if (daysUntilDue < 0) scoreA += 50;
        else if (daysUntilDue < 1) scoreA += 40;
        else if (daysUntilDue < 3) scoreA += 25;
        else if (daysUntilDue < 7) scoreA += 10;
      }
      if (b.dueDate) {
        const daysUntilDue = (new Date(b.dueDate).getTime() - Date.now()) / 86400000;
        if (daysUntilDue < 0) scoreB += 50;
        else if (daysUntilDue < 1) scoreB += 40;
        else if (daysUntilDue < 3) scoreB += 25;
        else if (daysUntilDue < 7) scoreB += 10;
      }
      return scoreB - scoreA;
    });
  }

  function getActiveDisplayList(): Task[] {
    const active = tasks.filter(t => !t.completed);
    if (isQueueMode && settings.queueSize > 0) {
      return queue.filter(q => !q.completed);
    }
    return active;
  }

  function getFocusTimeTotal(): number {
    return tasks.reduce((acc, t) => acc + (t.focusTimeSpent || 0), 0) + (parseInt(localStorage.getItem(METRIC_KEY) || '0', 10));
  }

  function addGlobalFocusTime(seconds: number) {
    const prev = parseInt(localStorage.getItem(METRIC_KEY) || '0', 10);
    localStorage.setItem(METRIC_KEY, (prev + seconds).toString());
  }

  // UI STATE UPDATES
  function updateUI() {
    renderTasksList();
    renderTaskSelectDropdown();
    renderStats();
    updateNavCounts();
    updateStreakDisplay();
    renderXpDisplay();
    renderQueueUI();
  }

  function renderQueueUI() {
    const banner = document.getElementById('queue-banner');
    const shuffleBtn = document.getElementById('shuffle-queue-btn');
    const viewLabel = document.getElementById('queue-view-label');
    const titleEl = document.getElementById('tasks-section-title');
    if (!banner || !shuffleBtn || !viewLabel || !titleEl) return;
    if (isQueueMode && settings.queueSize > 0) {
      banner.classList.remove('hidden');
      shuffleBtn.classList.remove('hidden');
      viewLabel.textContent = 'All Tasks';
      titleEl.textContent = "Today's Queue";
      const active = tasks.filter(t => !t.completed);
      const remaining = queue.filter(q => !q.completed).length;
      banner.innerHTML = `
        <svg class="w-3.5 h-3.5 text-gradient-develop-start shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        <span id="queue-banner-text">${remaining} of ${queue.length} tasks left in queue (${active.length} total active). Pick one and go.</span>
      `;
    } else {
      banner.classList.add('hidden');
      shuffleBtn.classList.add('hidden');
      viewLabel.textContent = 'Queue';
      titleEl.textContent = 'Active Nodes';
    }
  }

  function toggleDarkMode() {
    const html = document.documentElement;
    const isDark = html.classList.toggle('dark');
    localStorage.setItem('plan-today-theme', isDark ? 'dark' : 'light');
    updateDarkModeIcon(isDark);
  }

  function updateDarkModeIcon(isDark: boolean) {
    const sun = document.getElementById('dark-mode-icon-sun');
    const moon = document.getElementById('dark-mode-icon-moon');
    if (!sun || !moon) return;
    if (isDark) {
      sun.classList.add('hidden');
      moon.classList.remove('hidden');
    } else {
      sun.classList.remove('hidden');
      moon.classList.add('hidden');
    }
  }

  function updateNavCounts() {
    const completed = tasks.filter(t => t.completed).length;
    const total = tasks.length;
    
    const countEl = document.getElementById('nav-completed-count');
    if (countEl) {
      countEl.textContent = `${completed}/${total}`;
    }

    const totalSeconds = getFocusTimeTotal();
    const hours = Math.floor(totalSeconds / 3600);
    const minutes = Math.floor((totalSeconds % 3600) / 60);
    const navFocusEl = document.getElementById('nav-focus-time');
    if (navFocusEl) {
      navFocusEl.textContent = `${hours}h ${minutes}m`;
    }
  }

  function renderStats() {
    const completedCount = tasks.filter(t => t.completed).length;
    const totalCount = tasks.length;
    const pct = totalCount > 0 ? Math.round((completedCount / totalCount) * 100) : 0;

    const pctText = document.getElementById('stat-completion-pct');
    if (pctText) pctText.textContent = `${pct}%`;

    const pctBar = document.getElementById('stat-completion-bar');
    if (pctBar) {
      pctBar.style.width = `${pct}%`;
    }

    const totalFocusEl = document.getElementById('stat-total-focus');
    if (totalFocusEl) {
      const totalSec = getFocusTimeTotal();
      if (totalSec >= 3600) {
        totalFocusEl.textContent = `${(totalSec / 3600).toFixed(1)}h`;
      } else {
        totalFocusEl.textContent = `${Math.round(totalSec / 60)}m`;
      }
    }
  }

  function renderTaskSelectDropdown() {
    const select = document.getElementById('timer-task-select') as HTMLSelectElement;
    if (!select) return;

    // Preserve selection if it still exists
    const currentSel = select.value;
    select.innerHTML = '<option value="">General task focus</option>';

    tasks.filter(t => !t.completed).forEach(task => {
      const opt = document.createElement('option');
      opt.value = task.id;
      opt.textContent = `[${task.category.toUpperCase()}] ${task.title}`;
      opt.className = 'bg-surface-inverse text-white';
      if (task.id === currentSel) opt.selected = true;
      select.appendChild(opt);
    });
  }

  function renderTasksList() {
    const activeList = document.getElementById('active-tasks-list');
    const completedList = document.getElementById('completed-tasks-list');
    
    if (!activeList || !completedList) return;

    // Filter logic
    let filtered = tasks.filter(t => {
      const matchesFilter = filterType === 'all' || t.category === filterType;
      const matchesSearch = t.title.toLowerCase().includes(searchQuery.toLowerCase());
      return matchesFilter && matchesSearch;
    });

    // Sort logic
    const sortVal = (document.getElementById('task-sort-select') as HTMLSelectElement)?.value || 'newest';
    filtered.sort((a, b) => {
      if (sortVal === 'newest') return b.createdAt - a.createdAt;
      if (sortVal === 'oldest') return a.createdAt - b.createdAt;
      if (sortVal === 'priority') {
        const score = { high: 3, medium: 2, low: 1 };
        return score[b.priority] - score[a.priority];
      }
      if (sortVal === 'due') {
        if (!a.dueDate) return 1;
        if (!b.dueDate) return -1;
        return new Date(a.dueDate).getTime() - new Date(b.dueDate).getTime();
      }
      return 0;
    });

    const completedTasks = filtered.filter(t => t.completed);

    // Queue mode: show queue items first, then rest
    let activeTasks: Task[];
    if (isQueueMode && settings.queueSize > 0) {
      const queueIds = new Set(queue.filter(q => !q.completed).map(q => q.id));
      const queueItems = filtered.filter(t => !t.completed && queueIds.has(t.id));
      const restItems = filtered.filter(t => !t.completed && !queueIds.has(t.id));
      activeTasks = [...queueItems, ...restItems];
    } else {
      activeTasks = filtered.filter(t => !t.completed);
    }

    // Badges update
    const activeBadge = document.getElementById('active-tasks-badge');
    if (activeBadge) activeBadge.textContent = activeTasks.length.toString();

    const completedBadge = document.getElementById('completed-tasks-badge');
    if (completedBadge) completedBadge.textContent = completedTasks.length.toString();

    // Render active
    if (activeTasks.length === 0) {
      activeList.innerHTML = `
        <div class="border border-hairline border-dashed rounded-lg p-8 bg-canvas text-center shadow-level-1">
          <p class="body-sm text-mute">Nothing queued. The void stares back.</p>
          <p class="text-[11px] text-mute/80 mt-1 font-mono">Drop something in. Anything. ⌘⇧A</p>
        </div>
      `;
    } else {
      activeList.innerHTML = activeTasks.map(t => createTaskRowHTML(t)).join('');
    }

    // Render completed
    if (completedTasks.length === 0) {
      completedList.innerHTML = `
        <p class="body-sm text-mute text-center py-4">Nothing conquered yet. The war is young.</p>
      `;
    } else {
      completedList.innerHTML = completedTasks.map(t => createTaskRowHTML(t)).join('');
    }

    // Bind item listeners
    bindTaskItemEventListeners();
  }

  function createTaskRowHTML(task: Task): string {
    const priorityColors = {
      low: 'bg-cyan-soft text-cyan-deep border-cyan/20',
      medium: 'bg-warning-soft text-warning-deep border-warning/20',
      high: 'bg-error-soft text-error-deep border-error/20'
    };

    const isTimerActiveOnThis = linkedTaskId === task.id && timerRunning;
    const focusMinutes = Math.round((task.focusTimeSpent || 0) / 60);

    return `
      <div class="group border border-hairline rounded-md p-4 bg-canvas hover:border-hairline-strong transition-all shadow-level-2 hover:shadow-level-3 flex items-start justify-between gap-4 ${isTimerActiveOnThis ? 'ring-1 ring-cyan border-cyan' : ''}" data-id="${task.id}">
        <div class="flex items-start gap-3 flex-1 min-w-0">
          <input type="checkbox" class="custom-checkbox mt-1 task-complete-checkbox" ${task.completed ? 'checked' : ''} />
          
          <div class="space-y-1 flex-1 min-w-0">
            <span class="block body-md font-sans text-ink ${task.completed ? 'line-through text-mute/60' : ''} break-words leading-tight">
              ${escapeHTML(task.title)}
            </span>
            
            <!-- Metadata row -->
            <div class="flex flex-wrap items-center gap-2">
              <span class="caption-mono text-[10px] text-body uppercase border border-hairline bg-canvas-soft-2 px-1.5 py-0.2 rounded font-medium">
                ${task.category}
              </span>
              
              <span class="caption-mono text-[10px] uppercase border px-1.5 py-0.2 rounded font-medium ${priorityColors[task.priority]}">
                ${task.priority}
              </span>

              ${task.dueDate ? `
                <span class="caption-mono text-[10px] text-mute flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  ${task.dueDate}
                </span>
              ` : ''}

              ${focusMinutes > 0 ? `
                <span class="caption-mono text-[10px] text-violet-deep bg-violet-soft/30 border border-violet-soft px-1.5 py-0.2 rounded flex items-center gap-1">
                  <svg class="w-3 h-3 text-violet-deep" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  Focused: ${focusMinutes}m
                </span>
              ` : ''}
            </div>
          </div>
        </div>

        <!-- Action tools (always visible for low friction) -->
        <div class="flex items-center gap-1.5 shrink-0">
          ${!task.completed ? `
            <button class="task-focus-trigger p-1.5 hover:bg-canvas-soft-2 border border-hairline rounded transition-colors text-body hover:text-violet-deep" title="Focus on this task">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </button>
            <button class="task-lock-trigger p-1.5 hover:bg-canvas-soft-2 border border-hairline rounded transition-colors text-body hover:text-gradient-develop-start" title="Lock onto this task">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </button>
          ` : ''}
          <button class="task-delete-trigger p-1.5 hover:bg-error-soft/30 border border-hairline rounded transition-colors text-mute hover:text-error-deep" title="Delete task">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
            </svg>
          </button>
        </div>
      </div>
    `;
  }

  function bindTaskItemEventListeners() {
    document.querySelectorAll('.task-complete-checkbox').forEach(cb => {
      cb.addEventListener('change', (e) => {
        const id = (e.target as HTMLElement).closest('[data-id]')?.getAttribute('data-id');
        if (id) toggleTaskCompletion(id);
      });
    });

    document.querySelectorAll('.task-focus-trigger').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const id = (e.target as HTMLElement).closest('[data-id]')?.getAttribute('data-id');
        if (id) startFocusOnTask(id);
      });
    });

    document.querySelectorAll('.task-delete-trigger').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const id = (e.target as HTMLElement).closest('[data-id]')?.getAttribute('data-id');
        if (id) deleteLocalTask(id);
      });
    });

    document.querySelectorAll('.task-lock-trigger').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const id = (e.target as HTMLElement).closest('[data-id]')?.getAttribute('data-id');
        if (id) enterFocusLock(id);
      });
    });
  }

  // UTILITY HELPER
  function escapeHTML(str: string): string {
    return str.replace(/[&<>'"]/g, 
      tag => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[tag] || tag)
    );
  }

  // TASK MUTATIONS
  function toggleTaskCompletion(id: string) {
    const task = tasks.find(t => t.id === id);
    if (!task) return;

    const wasCompleted = task.completed;
    task.completed = !task.completed;
    
    if (task.completed && linkedTaskId === id) {
      linkedTaskId = null;
      const select = document.getElementById('timer-task-select') as HTMLSelectElement;
      if (select) select.value = '';
    }

    saveData();
    generateQueue();
    
    if (task.completed && !wasCompleted) {
      const xp = getTaskXp(task);
      addXp(xp);
      if (settings.streakType === 'tasks') recordActivity();
      showToast(`✅ "${task.title}" — +${xp} XP`);
      updateStreakDisplay();
    } else {
      showToast(task.completed ? 'Task completed!' : 'Task restored.');
    }
    
    updateUI();
  }

  function deleteLocalTask(id: string) {
    const index = tasks.findIndex(t => t.id === id);
    if (index === -1) return;

    const taskTitle = tasks[index].title;
    tasks.splice(index, 1);

    if (linkedTaskId === id) {
      linkedTaskId = null;
      const select = document.getElementById('timer-task-select') as HTMLSelectElement;
      if (select) select.value = '';
    }

    saveData();
    updateUI();
    showToast(`Deleted: "${taskTitle}"`);
  }

  function startFocusOnTask(id: string, skipScroll = false) {
    const task = tasks.find(t => t.id === id);
    if (!task) return;

    linkedTaskId = id;
    const select = document.getElementById('timer-task-select') as HTMLSelectElement;
    if (select) select.value = id;

    // Reset remaining if timer isn't running
    if (!timerRunning) {
      timerRemaining = timerDuration;
      updateTimerDisplay();
    }

    showToast(`CPU engine targeting: "${task.title}"`);
    if (!skipScroll) scrollToTimer();
  }

  function scrollToTimer() {
    const timerCard = document.getElementById('timer-toggle-btn');
    timerCard?.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  // TIMER ENGINE LOGIC
  function setupTimer() {
    const toggleBtn = document.getElementById('timer-toggle-btn');
    const resetBtn = document.getElementById('timer-reset-btn');
    const select = document.getElementById('timer-task-select') as HTMLSelectElement;
    const presets = document.getElementById('timer-presets');
    const zenToggle = document.getElementById('zen-timer-toggle');

    toggleBtn?.addEventListener('click', toggleTimer);
    zenToggle?.addEventListener('click', toggleTimer);
    resetBtn?.addEventListener('click', resetTimer);

    select?.addEventListener('change', (e) => {
      linkedTaskId = (e.target as HTMLSelectElement).value || null;
      showToast(linkedTaskId ? 'Focus session target updated.' : 'Session target reset to General.');
    });

    presets?.querySelectorAll('button').forEach(btn => {
      btn.addEventListener('click', (e) => {
        presets.querySelectorAll('button').forEach(b => b.classList.remove('active', 'text-white/90'));
        presets.querySelectorAll('button').forEach(b => b.classList.add('text-white/60'));
        
        const target = e.target as HTMLButtonElement;
        target.classList.add('active', 'text-white/90');
        target.classList.remove('text-white/60');

        const secs = parseInt(target.getAttribute('data-time') || '1500', 10);
        timerDuration = secs;
        resetTimer();
      });
    });
  }

  function toggleTimer() {
    if (timerRunning) {
      pauseTimer();
    } else {
      startTimer();
    }
  }

  function startTimer() {
    if (timerRunning) return;

    timerWasPaused = false;
    timerRunning = true;
    updateTimerControlUI(true);

    activeTimerId = window.setInterval(() => {
      timerRemaining--;
      focusAccumulatedThisSession++;

      // Log progress to the linked task periodically (every 5 seconds)
      if (linkedTaskId && focusAccumulatedThisSession % 5 === 0) {
        const task = tasks.find(t => t.id === linkedTaskId);
        if (task) {
          task.focusTimeSpent = (task.focusTimeSpent || 0) + 5;
          saveData();
          updateUI();
        }
      } else if (!linkedTaskId && focusAccumulatedThisSession % 5 === 0) {
        addGlobalFocusTime(5);
        updateUI();
      }

      if (timerRemaining <= 0) {
        handleTimerCompletion();
      } else {
        updateTimerDisplay();
      }
    }, 1000);

    showToast('Focus CPU session running.');
  }

  function pauseTimer() {
    if (!timerRunning || activeTimerId === null) return;

    timerWasPaused = true;
    window.clearInterval(activeTimerId);
    activeTimerId = null;
    timerRunning = false;

    updateTimerControlUI(false);
    showToast('Focus session paused.');
  }

  function resetTimer() {
    pauseTimer();
    timerRemaining = timerDuration;
    focusAccumulatedThisSession = 0;
    updateTimerDisplay();
    showToast('Timer logs reset.');
  }

  function handleTimerCompletion() {
    pauseTimer();
    timerRemaining = timerDuration;
    const wasPerfect = !timerWasPaused;
    focusAccumulatedThisSession = 0;
    updateTimerDisplay();

    playAlertSound();
    triggerConfetti();

    let completionMsg = 'Focus block completed! Well focused.';
    if (linkedTaskId) {
      const task = tasks.find(t => t.id === linkedTaskId);
      if (task) {
        completionMsg = `Focus block completed for: "${task.title}"!`;
      }
    }

    if (wasPerfect) {
      const bonusXp = 25;
      addXp(bonusXp);
      completionMsg += ` +${bonusXp} XP no-pause bonus!`;
    }

    showToast(completionMsg);
  }

  function playAlertSound() {
    // Generate a clean synth beep using Web Audio API so we don't need external audio files!
    try {
      const audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      
      osc.connect(gain);
      gain.connect(audioCtx.destination);
      
      osc.type = 'sine';
      osc.frequency.setValueAtTime(523.25, audioCtx.currentTime); // C5 note
      osc.frequency.setValueAtTime(659.25, audioCtx.currentTime + 0.15); // E5 note
      osc.frequency.setValueAtTime(783.99, audioCtx.currentTime + 0.3); // G5 note
      
      gain.gain.setValueAtTime(0.3, audioCtx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.55);
      
      osc.start(audioCtx.currentTime);
      osc.stop(audioCtx.currentTime + 0.6);
    } catch (e) {
      // AudioContext fallback
    }
  }

  function triggerConfetti() {
    const canvas = document.getElementById('confetti-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    canvas.classList.remove('hidden');
    const COLORS = ['#0070f3','#50e3c2','#f5a623','#ee0000','#7928ca','#ff0080','#00dfd8','#171717'];
    const pieces: any[] = [];
    for (let i = 0; i < 150; i++) {
      pieces.push({
        x: Math.random() * canvas.width, y: Math.random() * canvas.height - canvas.height,
        w: Math.random() * 10 + 5, h: Math.random() * 6 + 3,
        color: COLORS[Math.floor(Math.random() * COLORS.length)],
        vx: (Math.random() - 0.5) * 4, vy: Math.random() * 3 + 2,
        rot: Math.random() * 360, rotSpeed: (Math.random() - 0.5) * 8, opacity: 1
      });
    }
    let frames = 0;
    function animate() {
      frames++;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      let alive = false;
      pieces.forEach(p => {
        p.x += p.vx; p.y += p.vy; p.vy += 0.05; p.rot += p.rotSpeed;
        if (frames > 90) p.opacity -= 0.04;
        if (p.opacity > 0) {
          alive = true;
          ctx.save();
          ctx.translate(p.x, p.y);
          ctx.rotate((p.rot * Math.PI) / 180);
          ctx.globalAlpha = Math.max(0, p.opacity);
          ctx.fillStyle = p.color;
          ctx.fillRect(-p.w/2, -p.h/2, p.w, p.h);
          ctx.restore();
        }
      });
      if (alive) requestAnimationFrame(animate);
      else { ctx.clearRect(0,0,canvas.width,canvas.height); canvas.classList.add('hidden'); }
    }
    animate();
  }

  function updateTimerDisplay() {
    const mins = Math.floor(timerRemaining / 60);
    const secs = timerRemaining % 60;
    const timeStr = `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
    
    // Normal view
    const display = document.getElementById('timer-display');
    if (display) display.textContent = timeStr;

    // Progress bar
    const progressPct = (timerRemaining / timerDuration) * 100;
    const bar = document.getElementById('timer-progress-bar');
    if (bar) bar.style.width = `${progressPct}%`;

    // Zen view
    const zenDisplay = document.getElementById('zen-timer-display');
    if (zenDisplay) zenDisplay.textContent = timeStr;

    const zenBar = document.getElementById('zen-timer-progress');
    if (zenBar) zenBar.style.width = `${progressPct}%`;

    // Document title
    document.title = timerRunning 
      ? `(${timeStr}) Plan today. Play tomorrow.` 
      : 'Plan today. Play tomorrow. — Streamlined Task & Focus Canvas';
  }

  function updateTimerControlUI(isRunning: boolean) {
    const toggleBtn = document.getElementById('timer-toggle-btn');
    const toggleIcon = document.getElementById('timer-toggle-icon');
    const toggleText = document.getElementById('timer-toggle-text');
    const zenToggle = document.getElementById('zen-timer-toggle');

    if (!toggleBtn || !toggleIcon || !toggleText) return;

    if (isRunning) {
      toggleText.textContent = 'Pause Session';
      toggleIcon.innerHTML = '<path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>'; // pause icon
      toggleBtn.classList.remove('bg-white', 'text-[#0a0a0a]');
      toggleBtn.classList.add('bg-white/10', 'text-white', 'hover:bg-white/20');
      
      if (zenToggle) zenToggle.textContent = 'Pause Session';
    } else {
      toggleText.textContent = 'Start CPU Session';
      toggleIcon.innerHTML = '<path d="M8 5v14l11-7z"/>'; // play icon
      toggleBtn.classList.remove('bg-white/10', 'text-white', 'hover:bg-white/20');
      toggleBtn.classList.add('bg-white', 'text-[#0a0a0a]');
      
      if (zenToggle) zenToggle.textContent = 'Start Session';
    }
  }

