  // EXPORT/IMPORT UTILITIES
  function exportDatabase() {
    const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(tasks, null, 2));
    const dlAnchorElem = document.createElement('a');
    dlAnchorElem.setAttribute("href", dataStr);
    dlAnchorElem.setAttribute("download", `plan-today-play-tomorrow-${new Date().toISOString().split('T')[0]}.json`);
    dlAnchorElem.click();
    showToast('Database exported successfully.');
  }

  function importDatabase(event: any) {
    const file = event.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = function(e) {
      try {
        const imported = JSON.parse(e.target?.result as string);
        if (Array.isArray(imported)) {
          tasks = imported;
          saveData();
          updateUI();
          showToast('Tasks database imported successfully.');
        } else {
          showToast('Invalid JSON file format.', true);
        }
      } catch (err) {
        showToast('Error reading import file.', true);
      }
    };
    reader.readAsText(file);
  }

  function clearAllLogs() {
    if (confirm('Are you absolutely sure you want to purge your entire focus metrics database and all tasks? This is irreversible.')) {
      tasks = [];
      localStorage.removeItem(STORAGE_KEY);
      localStorage.removeItem(METRIC_KEY);
      saveData();
      updateUI();
      resetTimer();
      showToast('All system database logs cleared.');
    }
  }

  // CUSTOM TOAST ALERTS
  function showToast(message: string, isError = false) {
    const container = document.getElementById('toast-container');
    if (!container) return;

    const toast = document.createElement('div');
    toast.className = `p-4 rounded border text-xs font-mono flex items-center justify-between gap-3 shadow-level-4 bg-canvas transition-all duration-300 transform translate-y-2 opacity-0 pointer-events-auto ${
      isError 
        ? 'border-error/20 text-error-deep bg-error-soft/10' 
        : 'border-hairline text-ink bg-canvas'
    }`;
    toast.innerHTML = `
      <div class="flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full ${isError ? 'bg-error' : 'bg-success'}"></span>
        <span>${escapeHTML(message)}</span>
      </div>
      <button class="text-mute hover:text-ink font-sans font-bold">×</button>
    `;

    container.appendChild(toast);

    // Slide in
    setTimeout(() => {
      toast.classList.remove('translate-y-2', 'opacity-0');
    }, 10);

    const closeBtn = toast.querySelector('button');
    closeBtn?.addEventListener('click', () => {
      toast.classList.add('translate-y-2', 'opacity-0');
      setTimeout(() => toast.remove(), 300);
    });

    // Auto dismiss after 4 seconds
    setTimeout(() => {
      if (toast.parentNode) {
        toast.classList.add('translate-y-2', 'opacity-0');
        setTimeout(() => toast.remove(), 300);
      }
    }, 4000);
  }

  // COMMAND PALETTE
  let cmdIndex = 0;
  let matches: any[] = [];

  function openCommandPalette() {
    const palette = document.getElementById('cmd-palette');
    const dialog = document.getElementById('cmd-dialog');
    const input = document.getElementById('cmd-input') as HTMLInputElement;

    palette?.classList.remove('hidden');
    setTimeout(() => {
      dialog?.classList.remove('scale-95');
    }, 10);
    
    input.value = '';
    input.focus();
    cmdIndex = 0;
    
    renderCommandMatches();
  }

  function closeCommandPalette() {
    const palette = document.getElementById('cmd-palette');
    const dialog = document.getElementById('cmd-dialog');
    
    dialog?.classList.add('scale-95');
    setTimeout(() => {
      palette?.classList.add('hidden');
    }, 150);
  }

  function renderCommandMatches() {
    const input = document.getElementById('cmd-input') as HTMLInputElement;
    const query = input.value.trim().toLowerCase();
    const tasksList = document.getElementById('cmd-tasks-list');
    
    if (!tasksList) return;

    // Filter tasks
    const activeTasks = tasks.filter(t => !t.completed);
    const matchedTasks = query 
      ? activeTasks.filter(t => t.title.toLowerCase().includes(query)) 
      : activeTasks.slice(0, 3); // show top 3 when query is empty

    if (matchedTasks.length === 0) {
      tasksList.innerHTML = '<p class="text-xs text-mute px-3 py-2">No matching tasks found.</p>';
      matches = [];
    } else {
      tasksList.innerHTML = matchedTasks.map((t, idx) => `
        <button class="cmd-item cmd-task-item" data-id="${t.id}" data-index="${idx}">
          <span class="flex items-center gap-2 text-left truncate">
            <span class="w-1.5 h-1.5 rounded-full bg-success"></span>
            <span class="truncate">${escapeHTML(t.title)}</span>
          </span>
          <span class="text-[10px] font-mono text-mute uppercase">[${t.category}]</span>
        </button>
      `).join('');

      matches = matchedTasks;
      
      // Bind task clicks inside palette
      document.querySelectorAll('.cmd-task-item').forEach(item => {
        item.addEventListener('click', (e) => {
          const id = item.getAttribute('data-id');
          if (id) {
            startFocusOnTask(id);
            closeCommandPalette();
          }
        });
      });
    }

    updateCmdSelection();
  }

  function updateCmdSelection() {
    const items = document.querySelectorAll('.cmd-item');
    if (items.length === 0) return;
    items.forEach((item, idx) => {
      if (idx === cmdIndex) {
        item.classList.add('selected');
        item.scrollIntoView({ block: 'nearest' });
      } else {
        item.classList.remove('selected');
      }
    });
  }

  (function setupCommandPaletteEventsOnce() {
    const input = document.getElementById('cmd-input');
    const palette = document.getElementById('cmd-palette');

    palette?.addEventListener('click', (e) => {
      if (e.target === palette) closeCommandPalette();
    });

    input?.addEventListener('input', () => {
      cmdIndex = 0;
      renderCommandMatches();
    });

    input?.addEventListener('keydown', (e: any) => {
      const items = document.querySelectorAll('.cmd-item');
      if (items.length === 0) return;
      
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        cmdIndex = (cmdIndex + 1) % items.length;
        updateCmdSelection();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        cmdIndex = (cmdIndex - 1 + items.length) % items.length;
        updateCmdSelection();
      } else if (e.key === 'Enter') {
        e.preventDefault();
        const selected = items[cmdIndex] as HTMLElement;
        if (selected) executeCommandElement(selected);
      }
    });
  })();

  function executeCommandElement(el: HTMLElement) {
    const action = el.getAttribute('data-action');
    const id = el.getAttribute('data-id');
    const input = document.getElementById('cmd-input') as HTMLInputElement;
    const value = input.value.trim();

    if (action === 'create-task') {
      // Check if user specified a title after /add
      const prefix = '/add';
      let title = '';
      if (value.startsWith(prefix)) {
        title = value.substring(prefix.length).trim();
      }
      
      if (title) {
        const newTask: Task = {
          id: Date.now().toString(),
          title,
          category: 'work',
          priority: 'medium',
          dueDate: '',
          completed: false,
          focusTimeSpent: 0,
          createdAt: Date.now()
        };
        tasks.push(newTask);
        saveData();
        updateUI();
        showToast(`Scheduled: "${newTask.title}"`);
        closeCommandPalette();
      } else {
        // focus creation input
        const formInput = document.getElementById('task-title-input');
        formInput?.focus();
        closeCommandPalette();
        showToast('Input your task details.');
      }
    } else if (action === 'zen-toggle') {
      toggleZenMode();
      closeCommandPalette();
    } else if (action === 'clear-completed') {
      tasks = tasks.filter(t => !t.completed);
      saveData();
      updateUI();
      showToast('Cleared completed archive.');
      closeCommandPalette();
    } else if (action === 'quick-focus') {
      toggleTimer();
      closeCommandPalette();
    } else if (id) {
      // It's a task item
      startFocusOnTask(id);
      closeCommandPalette();
    }
  }

  // === NEW FEATURES: QUICK-ADD, SETTINGS, FOCUS LOCK ===

  function quickAddTask() {
    const input = document.getElementById('quick-add-input') as HTMLInputElement;
    if (!input || !input.value.trim()) return;
    const newTask: Task = {
      id: Date.now().toString(),
      title: input.value.trim(),
      category: 'work',
      priority: 'medium',
      dueDate: '',
      completed: false,
      focusTimeSpent: 0,
      createdAt: Date.now()
    };
    tasks.push(newTask);
    saveData();
    generateQueue();
    updateUI();
    showToast(`➕ Added: "${newTask.title}"`);
    input.value = '';
    input.focus();
  }

  (function setupSettingsModalOnce() {
    const modal = document.getElementById('settings-modal');
    modal?.addEventListener('click', function handler(e) {
      if (e.target === modal) { closeSettingsModal(); }
    });
  })();

  function openSettingsModal() {
    const modal = document.getElementById('settings-modal');
    const dialog = document.getElementById('settings-dialog');
    if (!modal || !dialog) return;
    modal.classList.remove('hidden');
    setTimeout(() => dialog.classList.remove('scale-95'), 10);
    const radios = document.querySelectorAll('input[name="streak-type"]');
    radios.forEach(r => {
      (r as HTMLInputElement).checked = (r as HTMLInputElement).value === settings.streakType;
    });
    const qs = document.getElementById('settings-queue-size') as HTMLSelectElement;
    if (qs) qs.value = settings.queueSize.toString();
  }

  function closeSettingsModal() {
    const modal = document.getElementById('settings-modal');
    const dialog = document.getElementById('settings-dialog');
    if (!modal || !dialog) return;
    dialog.classList.add('scale-95');
    setTimeout(() => modal.classList.add('hidden'), 150);
  }

  function enterFocusLock(taskId: string) {
    const task = tasks.find(t => t.id === taskId);
    if (!task) return;
    focusLockedTaskId = taskId;
    isFocusLocked = true;
    const lock = document.getElementById('focus-lock');
    const title = document.getElementById('focus-lock-title');
    const subtitle = document.getElementById('focus-lock-subtitle');
    const nextEl = document.getElementById('focus-lock-next');
    if (lock) lock.classList.remove('hidden');
    if (title) title.textContent = task.title;
    if (subtitle) subtitle.textContent = `${task.category} · ${task.priority} priority`;
    if (nextEl) {
      const queueIdx = queue.findIndex(t => t.id === taskId);
      if (queueIdx >= 0 && queueIdx < queue.length - 1) {
        nextEl.textContent = `Next: ${queue[queueIdx + 1].title}`;
      } else {
        nextEl.textContent = '— no more tasks in queue —';
      }
    }
    startFocusOnTask(taskId, true);
  }

  function exitFocusLock() {
    isFocusLocked = false;
    focusLockedTaskId = null;
    const lock = document.getElementById('focus-lock');
    if (lock) lock.classList.add('hidden');
  }

  // === ONBOARDING TOUR ===
  function startTour() {
    tourStep = 0;
    const overlay = document.getElementById('tour-overlay');
    const tooltip = document.getElementById('tour-tooltip');
    if (overlay) overlay.classList.remove('hidden');
    if (tooltip) tooltip.classList.remove('hidden');
    showTourStep();

    // Listen to resize and scroll to reposition the spotlight and tooltip dynamically
    window.addEventListener('resize', handleTourReposition);
    window.addEventListener('scroll', handleTourReposition, { passive: true });
  }

  function endTour() {
    const overlay = document.getElementById('tour-overlay');
    const tooltip = document.getElementById('tour-tooltip');
    const spotlight = document.getElementById('tour-spotlight');
    if (overlay) overlay.classList.add('hidden');
    if (tooltip) tooltip.classList.add('hidden');
    if (spotlight) spotlight.classList.add('hidden');
    tourStep = -1;
    localStorage.setItem(TOUR_KEY, 'true');

    // Clean up listeners
    window.removeEventListener('resize', handleTourReposition);
    window.removeEventListener('scroll', handleTourReposition);
  }

  function handleTourReposition() {
    if (tourStep >= 0 && tourStep < TOUR_STEPS.length) {
      const step = TOUR_STEPS[tourStep];
      const target = document.getElementById(step.targetId);
      if (target) {
        positionTourElements(target, step.placement);
      }
    }
  }

  function showTourStep() {
    const step = TOUR_STEPS[tourStep];
    if (!step) { endTour(); return; }

    const target = document.getElementById(step.targetId);
    if (!target) { endTour(); return; }

    // Title & desc
    const titleEl = document.getElementById('tour-title');
    const descEl = document.getElementById('tour-desc');
    const indicator = document.getElementById('tour-step-indicator');
    const prevBtn = document.getElementById('tour-prev-btn');
    const nextBtn = document.getElementById('tour-next-btn');
    if (titleEl) titleEl.textContent = step.title;
    if (descEl) descEl.textContent = step.desc;
    if (indicator) indicator.textContent = `${tourStep + 1} / ${TOUR_STEPS.length}`;

    // Prev/Next buttons
    if (prevBtn) {
      if (tourStep === 0) { prevBtn.classList.add('hidden'); } else { prevBtn.classList.remove('hidden'); }
    }
    if (nextBtn) {
      if (tourStep === TOUR_STEPS.length - 1) {
        nextBtn.textContent = 'Done';
      } else {
        nextBtn.textContent = 'Next';
      }
    }

    // Dots
    const dotsContainer = document.getElementById('tour-dots');
    if (dotsContainer) {
      dotsContainer.innerHTML = TOUR_STEPS.map((_, i) =>
        `<span class="w-1.5 h-1.5 rounded-full ${i === tourStep ? 'bg-primary' : 'bg-hairline-strong'} transition-all duration-300"></span>`
      ).join('');
    }

    target.scrollIntoView({ behavior: 'instant', block: 'center' });
    positionTourElements(target, step.placement);
  }

  function positionTourElements(target: HTMLElement, placement: string) {
    const spotlight = document.getElementById('tour-spotlight');
    const tooltip = document.getElementById('tour-tooltip');
    if (!spotlight || !tooltip) return;

    const rect = target.getBoundingClientRect();
    const pad = 8;

    // Spotlight
    spotlight.classList.remove('hidden');
    spotlight.style.top = `${rect.top - pad}px`;
    spotlight.style.left = `${rect.left - pad}px`;
    spotlight.style.width = `${rect.width + pad * 2}px`;
    spotlight.style.height = `${rect.height + pad * 2}px`;

    // Tooltip position
    const gap = 12;
    let top: number, left: number;
    const tipWidth = Math.min(320, window.innerWidth - 32);

    tooltip.style.width = `${tipWidth}px`;
    tooltip.classList.remove('hidden');
    const tipHeight = tooltip.offsetHeight; // Get the actual tooltip height dynamically

    if (placement === 'bottom') {
      top = rect.bottom + gap;
      left = Math.max(16, Math.min(rect.left + rect.width / 2 - tipWidth / 2, window.innerWidth - tipWidth - 16));
    } else if (placement === 'top') {
      top = rect.top - gap - tipHeight;
      if (top < 16) top = rect.bottom + gap; // fallback to bottom if not enough space
      left = Math.max(16, Math.min(rect.left + rect.width / 2 - tipWidth / 2, window.innerWidth - tipWidth - 16));
    } else {
      top = rect.bottom + gap;
      left = Math.max(16, Math.min(rect.left + rect.width / 2 - tipWidth / 2, window.innerWidth - tipWidth - 16));
    }

    tooltip.style.top = `${top}px`;
    tooltip.style.left = `${left}px`;
  }
  init();
  setupTimer();
</script>
