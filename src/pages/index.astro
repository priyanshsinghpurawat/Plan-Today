        </button>

        <div id="completed-tasks-wrapper" class="hidden border-t border-hairline bg-canvas p-4 space-y-3 transition-all duration-300">
          <div id="completed-tasks-list" class="space-y-3">
            <!-- Dynamic insertion -->
          </div>
        </div>
      </div>

    </div>
  </main>

  <!-- Zen Active Dashboard Overlay -->
  <div id="zen-container" class="hidden max-w-3xl w-full mx-auto px-4 py-24 flex-col items-center justify-center text-center space-y-12 transition-all duration-500">
    <div class="space-y-4">
      <span class="caption-mono text-xs text-cyan tracking-widest uppercase border border-cyan/30 px-3 py-1 rounded-full bg-cyan-deep/10">Zen CPU active</span>
      <h2 id="zen-task-title" class="display-lg text-ink">General task focus</h2>
      <p class="body-md text-mute max-w-md mx-auto">Take deep breath. Release all distractions. Concentrate.</p>
    </div>

    <div class="relative py-8">
      <div class="font-mono text-[9vw] md:text-9xl font-light text-ink tracking-tighter" id="zen-timer-display">25:00</div>
