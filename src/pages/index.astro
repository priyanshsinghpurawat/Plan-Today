---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Plan today. Play tomorrow. — Streamlined Task & Focus Canvas">
  <!-- Sticky Nav Bar -->
  <header class="sticky top-0 bg-canvas/80 backdrop-blur-md border-b border-hairline z-40 h-16 flex items-center transition-all duration-300">
    <div class="max-w-[1400px] w-full mx-auto px-4 md:px-6 flex items-center justify-between">
      <!-- Logo -->
      <a href="#" class="flex items-center gap-2 group select-none shrink-0">
        <svg class="w-5 h-5 text-ink transition-transform duration-300 group-hover:rotate-90" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M15 50 L35 70 L60 45" stroke="currentColor" stroke-width="10" stroke-linecap="round" stroke-linejoin="round"/>
          <polygon points="60,18 86,45 60,72" fill="currentColor"/>
        </svg>
        <span class="hidden sm:inline font-sans font-semibold tracking-[-0.6px] text-lg text-ink">
          Plan today. <span class="text-mute font-normal nav-hover-gradient">Play tomorrow.</span>
        </span>
      </a>

      <!-- Quick Metrics & Navigation -->
      <div class="flex items-center gap-2">
        <!-- Quick Stats Badge (Desktop) -->
        <div class="hidden lg:flex items-center gap-2 bg-canvas-soft border border-hairline px-3 py-1 rounded-md text-xs shadow-level-1">
          <div class="flex items-center gap-1 relative" id="nav-streak-container" title="Day streak">
            <span id="nav-streak-icon" class="text-warning text-xs">⚡</span>
            <span class="text-body font-mono font-medium" id="nav-streak-count">0</span>
            <span id="streak-glow" class="absolute -inset-2 rounded-full pointer-events-none opacity-0 transition-opacity duration-300" style="box-shadow: 0 0 12px 4px var(--color-warning);"></span>
          </div>
          <span class="text-hairline-strong">·</span>
          <div class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-success animate-pulse-soft"></span>
            <span class="text-body font-mono font-medium" id="nav-completed-count">0/0</span>
          </div>
          <span class="text-hairline-strong">·</span>
          <div class="flex items-center gap-1">
            <svg class="w-3 h-3 text-mute" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-body font-mono font-medium" id="nav-focus-time">0h 0m</span>
          </div>
        </div>

        <!-- Tool Buttons -->
        <div class="flex items-center gap-1">
          <button id="settings-toggle" class="w-8 h-8 flex items-center justify-center border border-hairline bg-canvas hover:bg-canvas-soft-2 text-ink rounded-md hover:border-hairline-strong transition-all shadow-level-1 cursor-pointer" title="Settings">
            <svg class="w-3.5 h-3.5 text-body" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </button>
        </div>

        <!-- Command Palette Trigger Button (Mock Search Style) -->
        <button id="cmd-palette-trigger" class="flex items-center justify-between gap-4 w-32 sm:w-44 md:w-48 lg:w-52 h-8 px-3 border border-hairline bg-canvas-soft hover:bg-canvas hover:border-hairline-strong text-mute rounded-md text-xs font-mono transition-all cursor-pointer shadow-level-1">
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 text-mute" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <span class="text-mute font-sans">Search...</span>
          </span>
          <kbd class="px-1.5 py-0.5 bg-canvas border border-hairline rounded text-[10px] text-mute font-mono">⌘K</kbd>
        </button>

        <!-- Theme & View Controls -->
        <div class="flex items-center gap-1">
          <button id="dark-mode-toggle" class="w-8 h-8 flex items-center justify-center border border-hairline bg-canvas hover:bg-canvas-soft-2 text-ink rounded-md hover:border-hairline-strong transition-all shadow-level-1 cursor-pointer" title="Toggle Dark Mode">
            <svg class="w-3.5 h-3.5 text-body" id="dark-mode-icon-sun" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            <svg class="w-3.5 h-3.5 text-body hidden" id="dark-mode-icon-moon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </button>
          <button id="toggle-zen-btn" class="w-8 h-8 flex items-center justify-center border border-hairline bg-canvas hover:bg-canvas-soft-2 text-ink rounded-md hover:border-hairline-strong transition-all shadow-level-1 cursor-pointer" title="Toggle Zen Mode (Esc)">
            <svg class="w-3.5 h-3.5 text-body" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </header>

  <!-- Hero Banner -->
  <section id="hero-section" class="max-w-[1400px] w-full mx-auto px-4 md:px-6 pt-12 pb-6 transition-all duration-500">
    <div class="max-w-3xl">
      <!-- Section Eyebrow -->
      <span class="caption-mono uppercase tracking-wider text-mute mb-3 block">Developer focus suite</span>
      <!-- Headline (Sentence case, period-terminated) -->
      <h1 class="display-xl text-ink mb-4">
        Plan today. <span class="animate-gradient-text">Play tomorrow.</span>
      </h1>
      <!-- Lead Paragraph -->
      <p class="body-lg text-body mb-6 max-w-2xl">
        A minimalist workspace engineered to keep your focus intact. Categorize tasks, log deep-work metrics with the focus engine, and claim your tomorrow.
      </p>

      <!-- AI Badge & Keyboard Tip -->
      <div class="inline-flex items-center gap-3 flex-wrap">
        <div class="inline-flex items-center gap-2 bg-surface-inverse text-on-surface-inverse border border-cyan/30 px-3 py-1.5 rounded-pill text-xs shadow-level-2">
          <span class="w-1.5 h-1.5 rounded-full bg-cyan animate-pulse"></span>
          <span class="font-mono font-medium tracking-wider text-[10px] uppercase">AI Focus Engine</span>
          <span class="text-[10px] font-mono text-cyan/60">v1</span>
        </div>
        <div class="inline-flex items-center gap-2 bg-canvas border border-hairline px-3 py-1.5 rounded-pill text-xs shadow-level-2">
          <span class="w-2 h-2 rounded-full bg-gradient-develop-start animate-pulse-soft"></span>
          <span class="text-body font-mono">Tip: Press <kbd class="font-semibold text-ink">Ctrl + K</kbd> to launch the command menu.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick-Add Bar -->
  <div id="quick-add-bar" class="max-w-[1400px] w-full mx-auto px-4 md:px-6 pb-4 relative z-10">
    <div class="flex items-center gap-3">
      <form id="quick-add-form" class="flex-1 flex items-center gap-2 bg-canvas border border-hairline hover:border-hairline-strong rounded-md px-3 py-2 transition-all shadow-level-1 focus-within:ring-1 focus-within:ring-cyan/50">
        <svg class="w-4 h-4 text-mute shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        <input type="text" id="quick-add-input" placeholder="Quick add task... (just hit Enter) — ⌘⇧A" class="flex-1 bg-transparent text-sm text-ink outline-none placeholder:text-mute/60" autocomplete="off" />
        <button type="submit" class="text-[11px] font-mono text-mute hover:text-ink bg-canvas-soft-2 hover:bg-canvas border border-hairline px-2 py-0.5 rounded transition-all">Add</button>
      </form>
      <span class="text-[10px] font-mono text-mute hidden md:block">⏎ add instantly</span>
    </div>
  </div>

  <!-- Main Workspace Grid -->
  <main id="app-grid" class="max-w-[1400px] w-full mx-auto px-4 md:px-6 pb-24 grid grid-cols-1 lg:grid-cols-12 gap-8 items-start relative transition-all duration-500">
    
    <!-- LEFT COLUMN: Creator, Focus Timer, Metrics (5/12 cols) -->
    <div id="left-column" class="lg:col-span-5 space-y-6 transition-all duration-500">
      
      <!-- active cpu focus timer (showcase dark band theme) -->
      <div class="bg-surface-inverse/90 backdrop-blur-sm text-on-surface-inverse rounded-lg p-6 shadow-level-4 relative overflow-hidden group timer-glass-card">
        <!-- Accent Glow background -->
        <div class="absolute inset-0 bg-radial-gradient from-violet-deep/10 via-transparent to-transparent pointer-events-none"></div>
        <div class="absolute -right-16 -top-16 w-36 h-36 bg-gradient-develop-end/10 rounded-full blur-2xl group-hover:scale-125 transition-transform duration-1000"></div>

        <div class="relative z-10 flex flex-col justify-between h-full">
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-cyan animate-pulse" id="timer-pulse-dot"></span>
              <span class="caption-mono uppercase tracking-widest text-cyan font-semibold">Active CPU Engine</span>
            </div>
            <div class="flex items-center gap-1.5" id="timer-presets">
              <button class="text-[10px] font-mono px-2 py-0.5 rounded border border-white/20 bg-white/5 hover:bg-white/10 text-white/90 active" data-time="1500">25m</button>
              <button class="text-[10px] font-mono px-2 py-0.5 rounded border border-white/20 bg-white/5 hover:bg-white/10 text-white/60" data-time="300">5m</button>
              <button class="text-[10px] font-mono px-2 py-0.5 rounded border border-white/20 bg-white/5 hover:bg-white/10 text-white/60" data-time="900">15m</button>
            </div>
          </div>

          <!-- Digital Timer Clock -->
          <div class="text-center py-4 relative">
            <span class="font-mono text-7xl font-light tracking-tighter" id="timer-display">25:00</span>
            <div class="w-full bg-white/10 h-[2px] mt-4 rounded-full overflow-hidden">
              <div class="bg-gradient-develop-end h-full w-full transition-all duration-300" id="timer-progress-bar"></div>
            </div>
          </div>

          <!-- Timer Actions & Link Task -->
          <div class="mt-4 space-y-4">
            <!-- Active Task Selector -->
            <div>
              <label for="timer-task-select" class="block text-[11px] font-mono uppercase tracking-wider text-white/50 mb-1">Focus Target</label>
              <select id="timer-task-select" class="w-full bg-white/5 border border-white/10 rounded-sm text-xs py-1.5 px-2 text-white outline-none focus:border-cyan/50 focus:ring-1 focus:ring-cyan/50 cursor-pointer">
                <option value="" class="bg-primary text-white">General task focus</option>
              </select>
            </div>

            <!-- Controls row -->
            <div class="flex items-center gap-3 pt-2">
              <button id="timer-toggle-btn" class="flex-1 bg-white hover:bg-white/90 text-[#0a0a0a] font-medium rounded-pill h-10 text-sm flex items-center justify-center gap-1.5 transition-all shadow-md">
                <svg class="w-4 h-4 fill-current" id="timer-toggle-icon" viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z" />
                </svg>
                <span id="timer-toggle-text">Start CPU Session</span>
              </button>
              <button id="timer-reset-btn" class="px-4 h-10 border border-white/20 bg-transparent hover:bg-white/5 text-white/90 rounded-pill text-sm transition-all">
                Reset
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- task creation panel (card-marketing style) -->
      <div class="bg-canvas border border-hairline rounded-lg p-6 shadow-level-2 relative">
        <h3 class="display-sm text-ink mb-1">Add task.</h3>
        <p class="body-sm text-mute mb-4">Input a new node into the task scheduler.</p>

        <form id="create-task-form" class="space-y-4">
          <!-- Title Input -->
          <div>
            <label for="task-title-input" class="block text-[11px] font-mono uppercase tracking-wider text-mute mb-1">Task Title</label>
            <input type="text" id="task-title-input" required placeholder="e.g. Optimize page speed metrics" class="w-full bg-canvas border border-hairline rounded-sm h-10 px-3 text-sm text-ink focus:outline-none focus:border-hairline-strong focus:ring-1 focus:ring-hairline-strong placeholder:text-mute/60" />
          </div>

          <!-- Grid: Tags & Priority -->
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="task-category-select" class="block text-[11px] font-mono uppercase tracking-wider text-mute mb-1">Category</label>
              <select id="task-category-select" class="w-full bg-canvas border border-hairline rounded-sm h-10 px-2 text-sm text-ink focus:outline-none focus:border-hairline-strong focus:ring-1 focus:ring-hairline-strong cursor-pointer">
                <option value="work">Work</option>
                <option value="personal">Personal</option>
                <option value="leisure">Leisure</option>
              </select>
            </div>

            <div>
              <label for="task-priority-select" class="block text-[11px] font-mono uppercase tracking-wider text-mute mb-1">Priority</label>
              <select id="task-priority-select" class="w-full bg-canvas border border-hairline rounded-sm h-10 px-2 text-sm text-ink focus:outline-none focus:border-hairline-strong focus:ring-1 focus:ring-hairline-strong cursor-pointer">
                <option value="low">Low</option>
                <option value="medium" selected>Medium</option>
                <option value="high">High</option>
              </select>
            </div>
          </div>

          <!-- Due Date -->
          <div>
            <label for="task-due-input" class="block text-[11px] font-mono uppercase tracking-wider text-mute mb-1">Due Date (Optional)</label>
            <input type="date" id="task-due-input" class="w-full bg-canvas border border-hairline rounded-sm h-10 px-3 text-sm text-ink focus:outline-none focus:border-hairline-strong focus:ring-1 focus:ring-hairline-strong" />
          </div>

          <!-- Submit -->
          <button type="submit" class="w-full bg-primary hover:bg-neutral-800 text-on-primary font-medium rounded-pill h-10 text-sm transition-all shadow-level-1 mt-2">
            Schedule Task
          </button>
        </form>
      </div>

      <!-- analytics and system commands (card-soft style) -->
      <div class="bg-canvas border border-hairline rounded-lg p-6 shadow-level-2">
        <h3 class="display-sm text-ink mb-1">Board metrics.</h3>
        <p class="body-sm text-mute mb-4">Live analytics from local session logs.</p>

        <!-- Stats Grid -->
        <div class="grid grid-cols-2 gap-3 mb-6">
          <div class="bg-canvas-soft border border-hairline rounded p-3">
            <span class="block text-[10px] font-mono uppercase tracking-wider text-mute mb-1">Completion</span>
            <span class="display-md text-ink" id="stat-completion-pct">0%</span>
            <div class="w-full bg-hairline h-1 rounded-full mt-2 overflow-hidden">
              <div class="bg-success h-full w-0 transition-all duration-500" id="stat-completion-bar"></div>
            </div>
          </div>
          <div class="bg-canvas-soft border border-hairline rounded p-3">
            <span class="block text-[10px] font-mono uppercase tracking-wider text-mute mb-1">Total Focused</span>
            <span class="display-md text-ink" id="stat-total-focus">0m</span>
            <span class="block text-[10px] text-mute mt-2 font-mono">across all tasks</span>
          </div>
          <div class="bg-canvas-soft border border-hairline rounded p-3">
            <span class="block text-[10px] font-mono uppercase tracking-wider text-mute mb-1">Level</span>
            <span class="display-md text-ink flex items-center gap-2">
              <svg class="w-4 h-4 text-warning" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
              <span id="stat-level">1</span>
            </span>
            <div class="w-full bg-hairline h-1 rounded-full mt-2 overflow-hidden">
              <div class="bg-warning h-full w-0 transition-all duration-500" id="stat-xp-bar"></div>
            </div>
            <span class="block text-[10px] text-mute mt-1 font-mono"><span id="stat-xp-current">0</span>/<span id="stat-xp-next">100</span> XP</span>
          </div>
          <div class="bg-canvas-soft border border-hairline rounded p-3">
            <span class="block text-[10px] font-mono uppercase tracking-wider text-mute mb-1">Best Streak</span>
            <span class="display-md text-ink" id="stat-best-streak">0</span>
            <span class="block text-[10px] text-mute mt-2 font-mono">🔥 consecutive days</span>
          </div>
        </div>

        <div class="space-y-3">
          <span class="block text-[10px] font-mono uppercase tracking-wider text-mute">System Utilities</span>
          <div class="flex flex-wrap gap-2">
            <button id="export-data-btn" class="flex-1 py-1.5 px-3 bg-canvas hover:bg-canvas-soft-2 text-ink border border-hairline rounded-sm text-xs font-mono transition-all flex items-center justify-center gap-1.5 shadow-level-1">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              Export JSON
            </button>
            <button id="import-data-btn" class="flex-1 py-1.5 px-3 bg-canvas hover:bg-canvas-soft-2 text-ink border border-hairline rounded-sm text-xs font-mono transition-all flex items-center justify-center gap-1.5 shadow-level-1">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
              </svg>
              Import JSON
            </button>
            <input type="file" id="import-file-input" class="hidden" accept=".json" />
          </div>
          <button id="clear-all-btn" class="w-full py-1.5 px-3 text-error hover:bg-error-soft/30 hover:text-error-deep border border-error/20 hover:border-error-deep/20 rounded-sm text-xs font-mono transition-all flex items-center justify-center gap-1.5">
            Reset All Database Logs
          </button>
        </div>
      </div>
    </div>

    <!-- RIGHT COLUMN: Task List and Filter Views (7/12 cols) -->
    <div id="right-column" class="lg:col-span-7 space-y-6 transition-all duration-500">
      
      <!-- Filter Bar & Search -->
      <div class="bg-canvas border border-hairline rounded-lg p-4 shadow-level-2 flex flex-col md:flex-row md:items-center justify-between gap-4">
        
        <!-- Tab Pills -->
        <div class="flex items-center gap-1 overflow-x-auto pb-1 md:pb-0" id="filter-tabs">
          <button class="tab-pill active" data-filter="all">All</button>
          <button class="tab-pill" data-filter="work">Work</button>
          <button class="tab-pill" data-filter="personal">Personal</button>
          <button class="tab-pill" data-filter="leisure">Leisure</button>
        </div>

        <!-- Search input -->
        <div class="relative flex-1 max-w-xs">
          <input type="text" id="task-search-input" placeholder="Search tasks..." class="w-full bg-canvas border border-hairline rounded-sm h-8 pl-8 pr-3 text-xs text-ink focus:outline-none focus:border-hairline-strong placeholder:text-mute/60" />
          <svg class="w-3.5 h-3.5 text-mute absolute left-2.5 top-1/2 -translate-y-1/2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
      </div>

      <!-- Active Tasks Container -->
      <div class="space-y-3">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2">
          <h2 class="display-sm text-ink flex items-center gap-2">
            <span id="tasks-section-title">Active Nodes</span>
            <span class="caption-mono text-xs text-mute border border-hairline px-2 py-0.5 rounded-full bg-canvas-soft-2" id="active-tasks-badge">0</span>
          </h2>
          <div class="flex items-center gap-2 flex-wrap">
            <button id="shuffle-queue-btn" class="text-[11px] font-mono text-body hover:text-ink border border-hairline px-2 py-0.5 rounded hover:bg-canvas transition-all cursor-pointer hidden" title="Shuffle queue">
              <svg class="w-3 h-3 inline-block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
              Shuffle
            </button>
            <button id="toggle-queue-view" class="text-[11px] font-mono text-body hover:text-ink border border-hairline px-2 py-0.5 rounded hover:bg-canvas transition-all cursor-pointer" title="Toggle queue view">
              <span id="queue-view-label">Queue</span>
            </button>
            <span class="text-[11px] font-mono text-mute">Sort by:</span>
            <select id="task-sort-select" class="bg-transparent border-0 text-[11px] font-mono text-ink outline-none cursor-pointer">
              <option value="newest">Newest first</option>
              <option value="oldest">Oldest first</option>
              <option value="priority">Priority</option>
              <option value="due">Due date</option>
            </select>
          </div>
        </div>

        <div id="queue-banner" class="hidden text-[11px] font-mono text-body bg-gradient-develop-start/5 border border-gradient-develop-start/20 px-3 py-2 rounded-md flex items-center gap-2">
