      if (focusLockedTaskId) {
        toggleTaskCompletion(focusLockedTaskId);
        exitFocusLock();
      }
    });

    // Tour
    document.getElementById('tour-next-btn')?.addEventListener('click', () => {
      if (tourStep === TOUR_STEPS.length - 1) { endTour(); }
      else { tourStep++; showTourStep(); }
    });
    document.getElementById('tour-prev-btn')?.addEventListener('click', () => {
      if (tourStep > 0) { tourStep--; showTourStep(); }
    });
    document.getElementById('tour-skip-btn')?.addEventListener('click', endTour);
    document.getElementById('restart-tour-btn')?.addEventListener('click', () => {
