  <!-- Command Palette Modal (ex-modal-card style) -->
  <div id="cmd-palette" class="fixed inset-0 bg-primary/40 backdrop-blur-sm z-50 flex items-start justify-center pt-24 hidden transition-opacity duration-300">
    <div class="bg-canvas border border-hairline w-full max-w-xl rounded-lg shadow-level-5 overflow-hidden flex flex-col mx-4 transition-transform duration-300 scale-95" id="cmd-dialog">
      <!-- Search Input Container -->
      <div class="relative border-b border-hairline p-4 flex items-center">
        <svg class="w-4 h-4 text-mute mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input type="text" id="cmd-input" placeholder="Type a command or task query..." class="w-full bg-transparent text-sm text-ink outline-none" autocomplete="off" />
        <span class="caption-mono text-[10px] text-mute border border-hairline px-2 py-0.5 rounded bg-canvas-soft-2 ml-2">ESC</span>
      </div>

      <!-- Content Area -->
      <div class="max-h-[350px] overflow-y-auto p-2" id="cmd-results">
        <!-- commands template -->
        <div class="text-[10px] font-mono uppercase tracking-wider text-mute px-3 py-1.5">System Commands</div>
