        <button id="toggle-completed-btn" class="w-full px-5 py-4 flex items-center justify-between hover:bg-canvas-soft hover:text-ink text-body transition-colors">
          <h2 class="display-sm text-sm font-semibold flex items-center gap-2">
            Archived / Completed
            <span class="caption-mono text-xs text-mute border border-hairline px-2 py-0.5 rounded-full bg-canvas" id="completed-tasks-badge">0</span>
          </h2>
          <svg class="w-4 h-4 text-mute transform transition-transform duration-300" id="completed-caret" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
